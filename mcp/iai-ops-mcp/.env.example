# --- Board API (Google OAuth) ---
# Desktop-app OAuth client for api.integratedai.com.au. Confirm with Dev/Alex
# whether one already exists (they mentioned clients for iOps/Engage) before
# registering a new one in Google Cloud Console.
IAI_BOARD_OAUTH_CLIENT_ID=
IAI_BOARD_OAUTH_CLIENT_SECRET=

# Identity attached to every board write. Defaults to "alex" (the board is
# Alex-held) if unset.
IAI_DEFAULT_AGENT=alex

# --- Fenn / iOps debrief ---
IOPS_DEBRIEF_TOKEN=

# --- Agent context store (DEV-010, experimental, may not be live) ---
AGENT_API_KEY=
